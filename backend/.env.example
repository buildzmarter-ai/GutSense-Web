# GutSense API Environment Variables
# Set these in Railway (or your cloud provider) as environment variables.
# Locally, the backend uses macOS Keychain via the Settings UI.

# Required: Anthropic API key for Claude analysis + synthesis
ANTHROPIC_API_KEY=sk-ant-...

# Required: Google API key for Gemini analysis
GOOGLE_API_KEY=AI...

# Optional: Bearer token for API authentication (leave blank to disable auth)
API_SECRET=

# Optional: Frontend URL for CORS (Railway sets PORT automatically)
FRONTEND_URL=https://gutsense.pages.dev
