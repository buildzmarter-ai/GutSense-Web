# GutSense API Environment Variables
# Set these in Railway (or your cloud provider) as environment variables.
# Locally, the backend uses macOS Keychain via the Settings UI.

# Required (at least one): Primary analysis provider API key
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Required: Google API key for Gemini analysis
GOOGLE_API_KEY=AI...

# Optional: Bearer token for API authentication (leave blank to disable auth)
API_SECRET=

# Optional: Comma-separated frontend URLs for CORS (Railway sets PORT automatically)
# Add all domains that should be allowed to call this API.
FRONTEND_URL=https://gutsense.industriallystrong.com,https://gutsense.pages.dev

# Optional: Set to "development" to also allow localhost CORS origins
ENVIRONMENT=production
